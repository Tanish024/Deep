# Deepfake Detector — Environment Variables
# Copy to .env and fill in your values

# Detection sensitivity (0.0 to 1.0)
# Lower = more sensitive, Higher = more strict
FAKE_THRESHOLD=0.5

# HuggingFace model cache location
# Model downloads here once and never again
HF_HOME=./models

# Your Render backend URL (set after Render deploy)
VITE_API_URL=https://YOUR-APP-NAME.onrender.com
